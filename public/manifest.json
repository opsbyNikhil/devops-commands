<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />

  <!-- DevOps infinity loop favicon — inline SVG, no external file needed -->
  <link rel="icon" type="image/svg+xml"
    href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='12' fill='%230f172a'/%3E%3Cpath d='M32 32 C30 26,24 22,20 23 C14 25,12 31,12 32 C12 33,14 39,20 41 C24 42,30 38,32 32 Z' fill='none' stroke='%233b82f6' stroke-width='3.5' stroke-linecap='round'/%3E%3Cpath d='M32 32 C34 26,40 22,44 23 C50 25,52 31,52 32 C52 33,50 39,44 41 C40 42,34 38,32 32 Z' fill='none' stroke='%2322d3ee' stroke-width='3.5' stroke-linecap='round'/%3E%3Cpath d='M29 29 Q32 32 35 29' fill='none' stroke='%233b82f6' stroke-width='3.5' stroke-linecap='round'/%3E%3Cpath d='M29 35 Q32 32 35 35' fill='none' stroke='%2322d3ee' stroke-width='3.5' stroke-linecap='round'/%3E%3Cpolygon points='0,0 -5,3 -5,-3' transform='translate(18,24) rotate(220)' fill='%233b82f6'/%3E%3Cpolygon points='0,0 -5,3 -5,-3' transform='translate(46,40) rotate(40)' fill='%2322d3ee'/%3E%3C/svg%3E" />

  <!-- Apple touch icon — DevOps infinity loop, larger -->
  <link rel="apple-touch-icon"
    href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 180 180'%3E%3Crect width='180' height='180' rx='36' fill='%230f172a'/%3E%3Cpath d='M90 90 C84 72,66 60,54 63 C38 68,32 86,32 90 C32 94,38 112,54 117 C66 120,84 108,90 90 Z' fill='none' stroke='%233b82f6' stroke-width='10' stroke-linecap='round'/%3E%3Cpath d='M90 90 C96 72,114 60,126 63 C142 68,148 86,148 90 C148 94,142 112,126 117 C114 120,96 108,90 90 Z' fill='none' stroke='%2322d3ee' stroke-width='10' stroke-linecap='round'/%3E%3Cpath d='M82 82 Q90 90 98 82' fill='none' stroke='%233b82f6' stroke-width='10' stroke-linecap='round'/%3E%3Cpath d='M82 98 Q90 90 98 98' fill='none' stroke='%2322d3ee' stroke-width='10' stroke-linecap='round'/%3E%3C/svg%3E" />

  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#0f172a" />
  <meta name="description" content="DevOps CMD Reference - Docker, Kubernetes, Terraform, Linux and AWS Commands" />
  <meta name="keywords" content="DevOps, Docker, Kubernetes, Terraform, Linux, AWS, Jenkins, Commands" />
  <meta name="author" content="DevOps CMD Reference" />
  <link rel="manifest" href="%PUBLIC_URL%/manifest.json" />

  <title>DevOps CMD Reference</title>

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #0f172a; font-family: 'Courier New', monospace; }

    .logo-preview {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 16px 24px;
      border-bottom: 1px solid rgba(34, 211, 238, 0.15);
    }

    .logo-preview svg {
      width: 48px;
      height: 48px;
    }

    .logo-preview span {
      font-size: 20px;
      font-weight: bold;
      color: #e2e8f0;
      letter-spacing: 0.05em;
    }

    .logo-preview span em {
      color: #22d3ee;
      font-style: normal;
    }
  </style>
</head>

<body>
  <noscript>You need to enable JavaScript to run DevOps CMD Reference.</noscript>

  <div id="root">
    <!-- Visible logo shown before React mounts — React will replace this -->
    <div class="logo-preview">

      <!-- DevOps infinity loop SVG logo -->
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64">
        <rect width="64" height="64" rx="12" fill="#0f172a"/>
        <rect x="2" y="2" width="60" height="60" rx="10" fill="none" stroke="#22d3ee" stroke-width="1" opacity="0.2"/>
        <!-- Left lobe — Dev (blue) -->
        <path d="M32 32 C30 26,24 22,20 23 C14 25,12 31,12 32 C12 33,14 39,20 41 C24 42,30 38,32 32 Z"
              fill="none" stroke="#3b82f6" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
        <!-- Right lobe — Ops (cyan) -->
        <path d="M32 32 C34 26,40 22,44 23 C50 25,52 31,52 32 C52 33,50 39,44 41 C40 42,34 38,32 32 Z"
              fill="none" stroke="#22d3ee" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
        <!-- Crossover top — blue over cyan -->
        <path d="M29 29 Q32 32 35 29" fill="none" stroke="#3b82f6" stroke-width="3.5" stroke-linecap="round"/>
        <!-- Crossover bottom — cyan over blue -->
        <path d="M29 35 Q32 32 35 35" fill="none" stroke="#22d3ee" stroke-width="3.5" stroke-linecap="round"/>
        <!-- Direction arrow on left lobe -->
        <polygon points="0,0 -5,3 -5,-3" transform="translate(18,24) rotate(220)" fill="#3b82f6"/>
        <!-- Direction arrow on right lobe -->
        <polygon points="0,0 -5,3 -5,-3" transform="translate(46,40) rotate(40)" fill="#22d3ee"/>
      </svg>

      <span>DevOps <em>CMD</em> Reference</span>
    </div>
  </div>
</body>

</html>